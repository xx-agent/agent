{
  "name": "@xx-agent/dao",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "dao": "bin/dao"
  },
  "workspaces": [
    "packages/*",
    "research/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:all": "npm run build && npm run build --workspaces --if-present",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:all": "npm run test --workspaces --if-present",
    "check": "tsc --noEmit && eslint . --ext .ts,.tsx && shellcheck *.sh",
    "check:all": "npm run check && npm run check --workspaces --if-present",
    "evolve": "tsx packages/dao-cli/src/dao/cli.ts",
    "sync": "tsx packages/dao-cli/src/dao/cli.ts sync",
    "example:pirate": "tsx packages/dao-core/examples/example.ts",
    "clean:all": "rm -rf dist && npm run clean --workspaces --if-present",
    "postinstall":"echo postinstall temp stop sync || npm run sync"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.21.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^4.1.2"
  }
}
