{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@xx-agent/dao-core": ["./packages/dao-core/src/index.ts"],
      "@xx-agent/dao-cli": ["./packages/dao-cli/src/main.ts"],
      "@xx-agent/dao-tui": ["./packages/dao-tui/src/index.ts"]
    }
  },
  "include": ["packages/*/src", "packages/*/examples"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".dao/ref"
  ]
}
