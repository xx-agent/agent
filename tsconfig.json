{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@xx-agent/xx-core": ["./packages/xx-core/src/index.ts"],
      "@xx-agent/xx-cli": ["./packages/xx-cli/src/main.ts"],
      "@xx-agent/xx-tui": ["./packages/xx-tui/src/index.ts"]
    }
  },
  "include": ["packages/*/src", "packages/*/examples"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".xx/ref"
  ]
}
