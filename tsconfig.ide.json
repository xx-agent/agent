{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@xx-agent/dao-core": [
        "./packages/dao-core/src/index.ts"
      ],
      "@xx-agent/dao-cli": [
        "./packages/dao-cli/src/main.ts"
      ],
      "@xx-agent/dao-tui": [
        "./packages/dao-tui/src/index.ts"
      ],
      "@eslint/js": [
        "./.dao/ref/github.com/eslint/eslint/v9.21.0/packages/js"
      ],
      "@eslint/js/*": [
        "./.dao/ref/github.com/eslint/eslint/v9.21.0/packages/js/*"
      ],
      "@types/node": [
        "./.dao/ref/github.com/DefinitelyTyped/DefinitelyTyped/22.0.0/types/node"
      ],
      "@types/node/*": [
        "./.dao/ref/github.com/DefinitelyTyped/DefinitelyTyped/22.0.0/types/node/*"
      ],
      "eslint": [
        "./.dao/ref/github.com/eslint/eslint/v9.21.0"
      ],
      "eslint/*": [
        "./.dao/ref/github.com/eslint/eslint/v9.21.0/*"
      ],
      "tsx": [
        "./.dao/ref/github.com/privatenumber/tsx/v4.7.0"
      ],
      "tsx/*": [
        "./.dao/ref/github.com/privatenumber/tsx/v4.7.0/*"
      ],
      "typescript": [
        "./.dao/ref/github.com/microsoft/TypeScript/5.0.0"
      ],
      "typescript/*": [
        "./.dao/ref/github.com/microsoft/TypeScript/5.0.0/*"
      ],
      "typescript-eslint": [
        "./.dao/ref/github.com/typescript-eslint/typescript-eslint/v8.25.0/packages/typescript-eslint/src/index.ts"
      ],
      "typescript-eslint/*": [
        "./.dao/ref/github.com/typescript-eslint/typescript-eslint/v8.25.0/packages/typescript-eslint/src/*"
      ],
      "vitest": [
        "./.dao/ref/github.com/vitest-dev/vitest/v4.1.2/packages/vitest"
      ],
      "vitest/*": [
        "./.dao/ref/github.com/vitest-dev/vitest/v4.1.2/packages/vitest/*"
      ],
      "@google/gemini-cli-core": [
        "./.dao/ref/github.com/google-gemini/gemini-cli/v0.34.0-preview.0"
      ],
      "@google/gemini-cli-core/*": [
        "./.dao/ref/github.com/google-gemini/gemini-cli/v0.34.0-preview.0/*"
      ],
      "@mariozechner/pi-tui": [
        "./.dao/ref/github.com/badlogic/pi-mono/v0.57.1/packages/tui/src/index.ts"
      ],
      "@mariozechner/pi-tui/*": [
        "./.dao/ref/github.com/badlogic/pi-mono/v0.57.1/packages/tui/src/*"
      ],
      "@opentelemetry/api": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/v1.9.0"
      ],
      "@opentelemetry/api/*": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/v1.9.0/*"
      ],
      "@opentelemetry/exporter-trace-otlp-grpc": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/0.213.0"
      ],
      "@opentelemetry/exporter-trace-otlp-grpc/*": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/0.213.0/*"
      ],
      "@opentelemetry/exporter-trace-otlp-http": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/0.213.0"
      ],
      "@opentelemetry/exporter-trace-otlp-http/*": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/0.213.0/*"
      ],
      "@opentelemetry/resources": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/v2.6.0"
      ],
      "@opentelemetry/resources/*": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/v2.6.0/*"
      ],
      "@opentelemetry/sdk-trace-base": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/v2.6.0"
      ],
      "@opentelemetry/sdk-trace-base/*": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/v2.6.0/*"
      ],
      "@opentelemetry/semantic-conventions": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/1.40.0"
      ],
      "@opentelemetry/semantic-conventions/*": [
        "./.dao/ref/github.com/open-telemetry/opentelemetry-js/1.40.0/*"
      ],
      "chalk": [
        "./.dao/ref/github.com/chalk/chalk/v5.6.2"
      ],
      "chalk/*": [
        "./.dao/ref/github.com/chalk/chalk/v5.6.2/*"
      ],
      "commander": [
        "./.dao/ref/github.com/tj/commander.js/v14.0.1"
      ],
      "commander/*": [
        "./.dao/ref/github.com/tj/commander.js/v14.0.1/*"
      ],
      "get-east-asian-width": [
        "./.dao/ref/github.com/sindresorhus/get-east-asian-width/v1.5.0"
      ],
      "get-east-asian-width/*": [
        "./.dao/ref/github.com/sindresorhus/get-east-asian-width/v1.5.0/*"
      ],
      "jsonc-parser": [
        "./.dao/ref/github.com/microsoft/node-jsonc-parser/v3.3.1"
      ],
      "jsonc-parser/*": [
        "./.dao/ref/github.com/microsoft/node-jsonc-parser/v3.3.1/*"
      ],
      "marked": [
        "./.dao/ref/github.com/markedjs/marked/v17.0.4"
      ],
      "marked/*": [
        "./.dao/ref/github.com/markedjs/marked/v17.0.4/*"
      ],
      "pino": [
        "./.dao/ref/github.com/pinojs/pino/v10.3.1"
      ],
      "pino/*": [
        "./.dao/ref/github.com/pinojs/pino/v10.3.1/*"
      ],
      "pino-pretty": [
        "./.dao/ref/github.com/pinojs/pino-pretty/v13.1.3"
      ],
      "pino-pretty/*": [
        "./.dao/ref/github.com/pinojs/pino-pretty/v13.1.3/*"
      ],
      "ws": [
        "./.dao/ref/github.com/websockets/ws/8.19.0"
      ],
      "ws/*": [
        "./.dao/ref/github.com/websockets/ws/8.19.0/*"
      ],
      "yaml": [
        "./.dao/ref/github.com/eemeli/yaml/v2.8.3/src/index.ts"
      ],
      "yaml/*": [
        "./.dao/ref/github.com/eemeli/yaml/v2.8.3/src/*"
      ],
      "@types/marked": [
        "./.dao/ref/github.com/DefinitelyTyped/DefinitelyTyped/5.0.2/types/marked"
      ],
      "@types/marked/*": [
        "./.dao/ref/github.com/DefinitelyTyped/DefinitelyTyped/5.0.2/types/marked/*"
      ],
      "@types/ws": [
        "./.dao/ref/github.com/DefinitelyTyped/DefinitelyTyped/8.18.1/types/ws"
      ],
      "@types/ws/*": [
        "./.dao/ref/github.com/DefinitelyTyped/DefinitelyTyped/8.18.1/types/ws/*"
      ],
      "@agentclientprotocol/sdk": [
        "./.dao/ref/github.com/agentclientprotocol/typescript-sdk/v0.16.1"
      ],
      "@agentclientprotocol/sdk/*": [
        "./.dao/ref/github.com/agentclientprotocol/typescript-sdk/v0.16.1/*"
      ],
      "@mariozechner/pi-coding-agent": [
        "./.dao/ref/github.com/badlogic/pi-mono/v0.61.0/packages/coding-agent/src/index.ts"
      ],
      "@mariozechner/pi-coding-agent/*": [
        "./.dao/ref/github.com/badlogic/pi-mono/v0.61.0/packages/coding-agent/src/*"
      ],
      "@vue/reactivity": [
        "./.dao/ref/github.com/vuejs/core/v3.5.31/packages/reactivity/src/index.ts"
      ],
      "@vue/reactivity/*": [
        "./.dao/ref/github.com/vuejs/core/v3.5.31/packages/reactivity/src/*"
      ],
      "yoga-layout": [
        "./.dao/ref/github.com/facebook/yoga/v3.2.1"
      ],
      "yoga-layout/*": [
        "./.dao/ref/github.com/facebook/yoga/v3.2.1/*"
      ],
      "yoga-layout-prebuilt": [
        "./.dao/ref/github.com/vadimdemedes/yoga-layout-prebuilt/v1.10.0"
      ],
      "yoga-layout-prebuilt/*": [
        "./.dao/ref/github.com/vadimdemedes/yoga-layout-prebuilt/v1.10.0/*"
      ],
      "@types/yoga-layout": [
        "./.dao/ref/github.com/DefinitelyTyped/DefinitelyTyped/1.9.2/types/yoga-layout"
      ],
      "@types/yoga-layout/*": [
        "./.dao/ref/github.com/DefinitelyTyped/DefinitelyTyped/1.9.2/types/yoga-layout/*"
      ]
    }
  },
  "include": ["packages/*/src", "packages/*/examples"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".dao",
    ".worktree"
  ]
}
